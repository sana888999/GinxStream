{
  "manifest_version": 2,
  "name": "Skool Video Downloader",
  "version": "1.0.0",
  "description": "Capture and download DRM videos from learn.editingskool.com (TagMango). Play the video, then click Download.",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage",
    "activeTab",
    "tabs",
    "http://127.0.0.1:47984/*",
    "https://learn.editingskool.com/*",
    "https://*.tagmango.com/*",
    "https://tagmango.com/*",
    "https://license-global.pallycon.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "skool-downloader@local",
      "strict_min_version": "91.0"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["https://learn.editingskool.com/*", "https://*.tagmango.com/*", "https://tagmango.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "browser_action": {
    "default_icon": "icon.svg",
    "default_title": "Skool Video Downloader",
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg"
  }
}
