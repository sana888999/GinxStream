{
  "manifest_version": 2,
  "name": "SanaGinx DRM Capture",
  "version": "2.0.0",
  "description": "Capture DASH MPD + DRM license data from any site (configurable rules). Sends to local SanaGinx download server.",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage",
    "activeTab",
    "tabs",
    "http://127.0.0.1:47984/*",
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "sanaginx-drm-capture@local",
      "strict_min_version": "91.0"
    }
  },
  "background": {
    "scripts": ["config.js", "background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "options_ui": {
    "page": "options.html",
    "browser_style": true
  },
  "browser_action": {
    "default_icon": "icon.svg",
    "default_title": "SanaGinx DRM Capture",
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg"
  }
}
